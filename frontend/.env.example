# Frontend API Configuration
# The URL of your backend API server

# For local development:
VITE_API_URL=http://localhost:5000

# Alternative variable name (also supported):
# VITE_API_BASE_URL=http://localhost:5000

# Notes:
# - This should point to your backend server URL
# - For production deployment, update this to your production API URL
# - The frontend will make all API requests to this base URL